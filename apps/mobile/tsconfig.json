{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@theme/*": [
        "src/theme/*"
      ],
      "@stores/*": [
        "src/stores/*"
      ],
      "@screens/*": [
        "src/screens/*"
      ],
      "@nav/*": [
        "src/navigation/*"
      ],
      "@components/*": [
        "src/components/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
  ]
}
