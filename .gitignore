# ─── ES-WMS Monorepo .gitignore ───────────────────────────────────────────────

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnp.*

# ── Expo / React Native ───────────────────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Android build artifacts
apps/mobile/android/
apps/mobile/.android/

# iOS build artifacts
apps/mobile/ios/
apps/mobile/.ios/

# Metro bundler cache
.metro-health-check*
metro-cache/

# EAS (Expo Application Services)
eas-build-local-nodejs/
.easignore

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
*.pem
*.key
*.p12
*.jks
*.keystore
google-services.json
GoogleService-Info.plist

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Backend (Node.js / Express) ───────────────────────────────────────────────
packages/server/dist/
packages/server/build/
packages/server/logs/
*.log

# ── Python IoT Engine ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
iot-engine/.venv/
iot-engine/venv/
iot-engine/*.egg-info/
iot-engine/dist/
iot-engine/.pytest_cache/

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
prisma/migrations/dev/

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
jest-results/
test-results/
playwright-report/
detox-artifacts/

# ── Build outputs ─────────────────────────────────────────────────────────────
build/
dist/
out/
*.apk
*.aab
*.ipa

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/