# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eswms?schema=public"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY_MOBILE="24h"
JWT_EXPIRY_WEB="8h"

# ─── IoT Engine API Key ─────────────────────────────────────────────────────
IOT_API_KEY="iot-engine-secret-key-change-in-production"

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ─── Geofence ────────────────────────────────────────────────────────────────
GEOFENCE_RADIUS_METERS=50

# ─── Fine Defaults ───────────────────────────────────────────────────────────
DEFAULT_FINE_AMOUNT=500
TRUCK_FULL_THRESHOLD_PERCENT=85

# ─── FCM (Future) ───────────────────────────────────────────────────────────
# FCM_SERVER_KEY=""
